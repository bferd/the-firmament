# Copy to .env and fill in real values — never commit .env to version control

# Node environment
NODE_ENV=production

# Port the app listens on inside the container
PORT=3000

# Absolute path to the SQLite database file
DB_PATH=/app/data/firmament.db

# Authelia base URL (used for session verification and sign-out)
AUTHELIA_URL=http://192.168.1.xxx:9091

# IP of the NPMplus reverse proxy — Remote-User header is only trusted from this IP
NPMPLUS_IP=192.168.x.xxx

# Note: InfluxDB URL/token and Borg-UI URL/token are stored in the Admin →
# Settings panel (SQLite). They are server-side only and never sent to the browser.

# Docker host binding — bind to the host IP that NPMplus can reach, not 0.0.0.0
# Set this in docker-compose.yml ports section: "${BIND_IP}:3000:3000"
BIND_IP=192.168.x.xxx

# Before first run with user: "1000:1000", ensure the data directory is writable:
#   sudo chown -R 1000:1000 ./data
